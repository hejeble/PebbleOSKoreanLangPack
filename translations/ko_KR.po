# Font-only language pack for PebbleOS (Korean glyphs, no UI translation).
#
# This catalog intentionally contains ZERO translated strings. The firmware
# looks up each English UI string in this .mo; every lookup misses, so the
# original English text is kept. The fonts packed alongside still render
# Hangul in notifications, emails, and messages. Only the header block below
# is required, so the pack installs as a valid selectable language and the
# firmware's version check works.
#
# To add UI translations later, add `msgid`/`msgstr` pairs whose msgids
# match resources/normal/base/lang/tintin.pot exactly.
#
msgid ""
msgstr ""
"Project-Id-Version: 1\n"
"Report-Msgid-Bugs-To: \n"
"PO-Revision-Date: 2026-07-02 00:00+0000\n"
"Last-Translator: Korean community font pack\n"
"Language-Team: Korean\n"
"Language: ko_KR\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Name: 한국어 (fonts)\n"
